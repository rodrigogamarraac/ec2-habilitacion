POSTGRES_USER=conference
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=conference
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DJANGO_SECRET_KEY=change-me-use-a-50-char-random-string
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,nginx,django

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=change_me_in_production
DJANGO_SUPERUSER_EMAIL=admin@example.com

FASTAPI_ENV=production
DATABASE_URL=postgresql+asyncpg://conference:change_me_in_production@postgres:5432/conference
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=60
