REDIS_PORT=6379

DEBUG=True
SECRET_KEY=your_django_secret_key

DJANGO_SUPERUSER_USERNAME=YOURUSER
DJANGO_SUPERUSER_EMAIL=YOU@example.com
DJANGO_SUPERUSER_PASSWORD=YOURPASSWORD
RATE_LIMIT=NUMBER/minute
