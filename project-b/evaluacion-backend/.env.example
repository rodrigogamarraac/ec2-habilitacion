DB_NAME=tickets
DB_USER=your_postgres_user
DB_PASSWORD=your_postgres_password
DB_HOST=localhost
DB_PORT=5432

POSTGRES_URL="postgresql://your_postgres_user:your_postgres_password@localhost:5432/tickets"

PROJECT_NAME=tickets
